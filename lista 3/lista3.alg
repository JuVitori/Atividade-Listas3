algoritmo "soma_tres_numeros"
// Funçăo :
// Autor : Julia Vitoria S.S
// Data : 13/04/2026
// Seçăo de Declaraçőes 
var
  n1, n2, n3, soma: real

inicio
   escreva("Digite o valor do número um: ")
   leia(n1)
   
   escreva("Digite o valor do número dois: ")
   leia(n2)
   
   escreva("Digite o valor do número tręs: ")
   leia(n3)
   
   soma <- n1 + n2 + n3
   
   escreva("A soma dos tręs números foi: ", soma)
fimalgoritmo
